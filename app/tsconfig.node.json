{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.cache/rug-node.tsbuildinfo",
    "incremental": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],

    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["vite.config.ts", "seed-markets.ts"]
}
